#: libscarecrow-desktop/gnome-languages.c:717
msgid "Unspecified"
msgstr "Sin especificar"

#. TRANSLATORS: Used to distinguish the labels representing the gez_ER
#. and gez_ET locales from gez_ER@abegede respective gez_ET@abegede. The
#. difference is related to collation.
#: libscarecrow-desktop/gnome-languages.c:1382
msgid "Abegede"
msgstr "Abegede"

#. TRANSLATORS: Used to distinguish Cyrillic from Latin written language variants.
#: libscarecrow-desktop/gnome-languages.c:1384
msgid "Cyrillic"
msgstr "CirГӯlico"

#. TRANSLATORS: Also known as "Nagari", a written variant for many languages
#. of the Indian subcontinent. See:
#. https://en.wikipedia.org/wiki/Devanagari
#: libscarecrow-desktop/gnome-languages.c:1388
msgid "Devanagari"
msgstr "Devanagari"

#. TRANSLATORS: Used to distinguish the label representing the tt_RU
#. locale from tt_RU@iqtelif. It's a special alphabet for Tatar.
#: libscarecrow-desktop/gnome-languages.c:1391
msgid "IQTElif"
msgstr "IQTElif"

#. TRANSLATORS: The alphabet/script, not the language. Used to distinguish
#. Latin from Cyrillic written language variants.
#: libscarecrow-desktop/gnome-languages.c:1394
msgid "Latin"
msgstr "Latino"

#. TRANSLATORS: "Saho" is a variant of the Afar language. Used to
#. distinguish the label representing the aa_ER locale from aa_ER@saaho.
#: libscarecrow-desktop/gnome-languages.c:1397
msgid "Saho"
msgstr "Saho"

#. TRANSLATORS: "Valencia" is a dialect of the Catalan language spoken
#. in Valencia. Used to distinguish the label representing the ca_ES
#. locale from ca_ES@valencia.
#: libscarecrow-desktop/gnome-languages.c:1401
msgid "Valencia"
msgstr "Valenciano"

#: libscarecrow-desktop/gnome-rr-config.c:754
#, c-format
msgid "CRTC %d cannot drive output %s"
msgstr "el CRTC %d no puede conducir la salida %s"

#: libscarecrow-desktop/gnome-rr-config.c:761
#, c-format
msgid "output %s does not support mode %dx%d@%dHz"
msgstr "la salida %s no soporta el modo %dx%d@%dHz"

#: libscarecrow-desktop/gnome-rr-config.c:772
#, c-format
msgid "CRTC %d does not support rotation=%d"
msgstr "el CRTC %d no soporta la rotaciГіn=%d"

#: libscarecrow-desktop/gnome-rr-config.c:785
#, c-format
msgid ""
"output %s does not have the same parameters as another cloned output:\n"
"existing mode = %d, new mode = %d\n"
"existing coordinates = (%d, %d), new coordinates = (%d, %d)\n"
"existing rotation = %d, new rotation = %d"
msgstr ""
"la salida %s no tiene los mismos parГЎmetros que otra salida clonada:\n"
"modo existente = %d, modo nuevo = %d\n"
"coordenadas existentes = (%d, %d), coordenadas nuevas = (%d, %d)\n"
"rotaciГіn existente = %d, rotaciГіn nueva = %d"

#: libscarecrow-desktop/gnome-rr-config.c:800
#, c-format
msgid "cannot clone to output %s"
msgstr "no se puede clonar la salida en %s"

#: libscarecrow-desktop/gnome-rr-config.c:926
#, c-format
msgid "Trying modes for CRTC %d\n"
msgstr "Intentando modos para el CRTC %d\n"

#: libscarecrow-desktop/gnome-rr-config.c:950
#, c-format
msgid "CRTC %d: trying mode %dx%d@%dHz with output at %dx%d@%dHz (pass %d)\n"
msgstr ""
"CRTC %d: intentando el modo %dx%d@%dHz con salida en %dx%d@%dHz (pasada %d)\n"

#: libscarecrow-desktop/gnome-rr-config.c:997
#, c-format
msgid ""
"could not assign CRTCs to outputs:\n"
"%s"
msgstr ""
"no se pudieron asignar los CRTC a las salidas:\n"
"%s"

#: libscarecrow-desktop/gnome-rr-config.c:1001
#, c-format
msgid ""
"none of the selected modes were compatible with the possible modes:\n"
"%s"
msgstr ""
"ninguno de los modos seleccionados es compatible con los modos posibles:\n"
"%s"

#. Translators: the "requested", "minimum", and
#. * "maximum" words here are not keywords; please
#. * translate them as usual.
#: libscarecrow-desktop/gnome-rr-config.c:1082
#, c-format
msgid ""
"required virtual size does not fit available size: requested=(%d, %d), "
"minimum=(%d, %d), maximum=(%d, %d)"
msgstr ""
"el tamaГұo virtual requerido no se ajusta al espacio disponible: "
"requerido=(%d, %d), mГӯnimo=(%d, %d), mГЎximo=(%d, %d)"

#: libscarecrow-desktop/gnome-wall-clock.c:258
msgctxt "time separator"
msgid "вҲ¶"
msgstr "вҲ¶"

# R:S hora:min
# e numero de dia
# b mes
# a dia
#. Translators: This is the time format with full date
#. plus day used in 24-hour mode. Please keep the under-
#. score to separate the date from the time.
#: libscarecrow-desktop/gnome-wall-clock.c:340
msgid "%a %b %-e_%R:%S"
msgstr "%a %e de %-b_%R:%S"

#: libscarecrow-desktop/gnome-wall-clock.c:341
msgid "%a %b %-e_%R"
msgstr "%a %e de %-b_%R"

#. Translators: This is the time format with full date
#. used in 24-hour mode. Please keep the underscore to
#. separate the date from the time.
#: libscarecrow-desktop/gnome-wall-clock.c:346
msgid "%b %-e_%R:%S"
msgstr "%e de %-b_%R:%S"

#: libscarecrow-desktop/gnome-wall-clock.c:347
msgid "%b %-e_%R"
msgstr "%e de %-b_%R"

#. Translators: This is the time format with day used
#. in 24-hour mode.
#: libscarecrow-desktop/gnome-wall-clock.c:351
msgid "%a %R:%S"
msgstr "%a %R:%S"

#: libscarecrow-desktop/gnome-wall-clock.c:352
msgid "%a %R"
msgstr "%a %R"

#. Translators: This is the time format without date used
#. in 24-hour mode.
#: libscarecrow-desktop/gnome-wall-clock.c:356
msgid "%R:%S"
msgstr "%R:%S"

#: libscarecrow-desktop/gnome-wall-clock.c:357
msgid "%R"
msgstr "%R"

#. Translators: This is a time format with full date
#. plus day used for AM/PM. Please keep the under-
#. score to separate the date from the time.
#: libscarecrow-desktop/gnome-wall-clock.c:365
msgid "%a %b %-e_%l:%M:%S %p"
msgstr "%a %e de %-b_%l:%M:%S %p"

#: libscarecrow-desktop/gnome-wall-clock.c:366
msgid "%a %b %-e_%l:%M %p"
msgstr "%a %e de %-b_%l:%M %p"

#. Translators: This is a time format with full date
#. used for AM/PM. Please keep the underscore to
#. separate the date from the time.
#: libscarecrow-desktop/gnome-wall-clock.c:371
msgid "%b %-e_%l:%M:%S %p"
msgstr "%e de %-b_%l:%M:%S %p"

#: libscarecrow-desktop/gnome-wall-clock.c:372
msgid "%b %-e_%l:%M %p"
msgstr "%e de %-b_%l:%M %p"

#. Translators: This is a time format with day used
#. for AM/PM.
#: libscarecrow-desktop/gnome-wall-clock.c:376
msgid "%a %l:%M:%S %p"
msgstr "%a %l:%M:%S %p"

#: libscarecrow-desktop/gnome-wall-clock.c:377
msgid "%a %l:%M %p"
msgstr "%a %l:%M %p"

#. Translators: This is a time format without date used
#. for AM/PM.
#: libscarecrow-desktop/gnome-wall-clock.c:381
msgid "%l:%M:%S %p"
msgstr "%l:%M:%S %p"

#: libscarecrow-desktop/gnome-wall-clock.c:382
msgid "%l:%M %p"
msgstr "%l:%M %p"

